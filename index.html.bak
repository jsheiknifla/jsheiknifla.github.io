            <!-- Career Goals -->
            <div class="glass-panel contact-info">
                <h3 style="text-align: center; margin-bottom: 2rem; color: var(--cyber-blue); font-family: var(--font-heading); font-weight: 700;">Cybersecurity Career Roadmap</h3>
                <div class="roadmap">
                    <div class="glass-panel roadmap-step">Junior SOC Analyst (Entry)</div>
                    <div class="roadmap-arrow"><i class="fas fa-arrow-down"></i></div>
                    <div class="glass-panel roadmap-step">Security Analyst</div>
                    <div class="roadmap-arrow"><i class="fas fa-arrow-down"></i></div>
                    <div class="glass-panel roadmap-step" style="background: rgba(79, 142, 247, 0.1);">Threat Hunter / Incident Responder</div>
                    <div class="roadmap-arrow"><i class="fas fa-arrow-down"></i></div>
                    <div class="glass-panel roadmap-step" style="background: rgba(255, 95, 162, 0.1);">DFIR Specialist / Blue Team Lead</div>
                </div>
            </div>
            
        </div>
    </section>

    <!-- GitHub Stats Section -->
    <section class="container reveal">
        <h2 class="section-title">GitHub Activity & Contributions</h2>
        <div class="github-grid">
            <div class="glass-panel github-card">
                <!-- Using sheikniflaj username for real profile stats -->
                <img src="https://github-readme-stats.vercel.app/api?username=sheikniflaj&show_icons=true&theme=transparent&hide_border=true&title_color=4F8EF7&text_color=1A1A2E&icon_color=FF5FA2" alt="GitHub Stats">
            </div>
            <div class="glass-panel github-card">
                <img src="https://github-readme-stats.vercel.app/api/top-langs/?username=sheikniflaj&layout=compact&theme=transparent&hide_border=true&title_color=4F8EF7&text_color=1A1A2E" alt="Top Languages">
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="container reveal">
        <h2 class="section-title">Let's Connect</h2>
        <div class="contact-container">
            <div class="glass-panel contact-info">
                <div>
                    <h3 style="margin-bottom: 2rem; font-family: var(--font-heading); font-weight: 700; color: var(--cyber-blue);">Connect Directly</h3>
                    
                    <div class="contact-item">
                        <div class="contact-icon"><i class="fas fa-envelope"></i></div>
                        <div class="contact-details">
                            <strong>Email</strong>
                            <a href="mailto:sheiknifla@example.com">sheiknifla@example.com</a>
                        </div>
                    </div>
                    
                    <div class="contact-item">
                        <div class="contact-icon"><i class="fab fa-linkedin-in"></i></div>
                        <div class="contact-details">
                            <strong>LinkedIn</strong>
                            <a href="https://linkedin.com/in/sheikniflaj" target="_blank">linkedin.com/in/sheikniflaj</a>
                        </div>
                    </div>

                    <div class="contact-item">
                        <div class="contact-icon"><i class="fab fa-github"></i></div>
                        <div class="contact-details">
                            <strong>GitHub</strong>
                            <a href="https://github.com/sheikniflaj" target="_blank">github.com/sheikniflaj</a>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 2rem;">
                    <button class="btn btn-primary resume-btn" style="width: 100%;"><i class="fas fa-file-pdf"></i> Download Full Resume</button>
                </div>
            </div>

            <div class="glass-panel contact-form">
                <form id="contactForm">
                    <div class="form-group">
                        <input type="text" id="contactName" class="form-control" placeholder="Your Name" required autocomplete="name">
                    </div>
                    <div class="form-group">
                        <input type="email" id="contactEmail" class="form-control" placeholder="Your Email" required autocomplete="email">
                    </div>
                    <div class="form-group">
                        <textarea id="contactMessage" class="form-control" placeholder="Your Message" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width: 100%;">
                        <i class="fas fa-paper-plane"></i> Send Message
                    </button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p style="font-weight: 600;">Made with <i class="fas fa-heart" style="color: var(--accent-pink);"></i> by Sheik Nifla J &copy; 2026</p>
            <div class="footer-tech">
                <span>HTML5</span> &bull; 
                <span>CSS3 Variables</span> &bull; 
                <span>Vanilla JS</span> &bull; 
                <span>Glassmorphism UI</span> &bull; 
                <span>Responsive Design</span>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script>
        // Custom Cursor Glow Effect
        const cursorGlow = document.getElementById('cursorGlow');
        
        document.addEventListener('mousemove', (e) => {
            cursorGlow.style.left = e.clientX + 'px';
            cursorGlow.style.top = e.clientY + 'px';
        });

        // Scroll Progress Bar & Back to Top Button visibility
        const scrollProgress = document.getElementById('scrollProgress');
        const backToTopBtn = document.getElementById('backToTop');
        const navbar = document.getElementById('navbar');

        window.addEventListener('scroll', () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            
            scrollProgress.style.width = scrolled + '%';
            
            // Show/Hide Back to Top button
            if (winScroll > 300) {
                backToTopBtn.classList.add('show');
            } else {
                backToTopBtn.classList.remove('show');
            }

            // Navbar shadow adjustment on scroll
            if (winScroll > 50) {
                navbar.style.boxShadow = '0 5px 20px rgba(0,0,0,0.05)';
                navbar.style.background = 'rgba(255, 255, 255, 0.85)';
            } else {
                navbar.style.boxShadow = 'none';
                navbar.style.background = 'rgba(255, 255, 255, 0.7)';
            }

            // Highlighting active section link
            const sections = document.querySelectorAll('section');
            const navItems = document.querySelectorAll('.nav-item');
            
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (winScroll >= sectionTop - 180) {
                    current = section.getAttribute('id');
                }
            });

            navItems.forEach(item => {
                item.classList.remove('active');
                if (item.getAttribute('href') === `#${current}`) {
                    item.classList.add('active');
                }
            });
        });

        // Smooth Back to Top
        backToTopBtn.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });

        // Toast Notification System
        const toastContainer = document.getElementById('toastContainer');
        
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            
            const iconClass = type === 'success' ? 'fa-check-circle' : 'fa-info-circle';
            toast.innerHTML = `
                <i class="fas ${iconClass}"></i>
                <span>${message}</span>
            `;
            
            toastContainer.appendChild(toast);
            
            // Trigger animation frame to ensure the transition happens
            requestAnimationFrame(() => {
                toast.classList.add('show');
            });
            
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => {
                    toast.remove();
                }, 400);
            }, 3500);
        }

        // Navbar Hamburger Menu for mobile devices
        const navToggle = document.getElementById('navToggle');
        const navLinks = document.getElementById('navLinks');
        
        navToggle.addEventListener('click', () => {
            navLinks.classList.toggle('active');
            const icon = navToggle.querySelector('i');
            if (navLinks.classList.contains('active')) {
                icon.classList.remove('fa-bars');
                icon.classList.add('fa-times');
            } else {
                icon.classList.remove('fa-times');
                icon.classList.add('fa-bars');
            }
        });

        // Close hamburger menu when a menu item is clicked
        document.querySelectorAll('.nav-item').forEach(link => {
            link.addEventListener('click', () => {
                navLinks.classList.remove('active');
                const icon = navToggle.querySelector('i');
                icon.classList.remove('fa-times');
                icon.classList.add('fa-bars');
            });
        });

        // Reveal Elements on Scroll
        function reveal() {
            const reveals = document.querySelectorAll('.reveal');
            for (let i = 0; i < reveals.length; i++) {
                const windowHeight = window.innerHeight;
                const elementTop = reveals[i].getBoundingClientRect().top;
                const elementVisible = 100;
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add('active');
                }
            }
        }
        window.addEventListener('scroll', reveal);
        reveal(); // Trigger initial on-load checks

        // Typing Effect
        const roles = [
            "Junior SOC Analyst", 
            "Security Analyst", 
            "Threat Detection Specialist", 
            "Incident Responder", 
            "GRC Professional"
        ];
        let roleIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        const typingElement = document.getElementById('typingText');

        function type() {
            const currentRole = roles[roleIndex];
            
            if (isDeleting) {
                typingElement.textContent = currentRole.substring(0, charIndex - 1);
                charIndex--;
            } else {
                typingElement.textContent = currentRole.substring(0, charIndex + 1);
                charIndex++;
            }

            let typeSpeed = isDeleting ? 40 : 80;

            if (!isDeleting && charIndex === currentRole.length) {
                typeSpeed = 1800; // Pause at completion
                isDeleting = true;
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                roleIndex = (roleIndex + 1) % roles.length;
                typeSpeed = 400; // Pause before next word
            }

            setTimeout(type, typeSpeed);
        }
        setTimeout(type, 1000); // Start delay

        // Tilt effect for Project and Stat Cards
        const tiltCards = document.querySelectorAll('.project-card, .stat-card');
        tiltCards.forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                const xPct = x / rect.width - 0.5;
                const yPct = y / rect.height - 0.5;
                card.style.transform = `perspective(1000px) rotateX(${yPct * -8}deg) rotateY(${xPct * 8}deg) translateY(-5px)`;
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) translateY(0)';
            });
        });

        // Contact Form submission handler
        const contactForm = document.getElementById('contactForm');
        contactForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const name = document.getElementById('contactName').value;
            showToast(`Thank you, ${name}! Your security message has been sent successfully.`);
            contactForm.reset();
        });

        // Resume Download button handler
        document.querySelectorAll('.resume-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                showToast("Resume download started! (Make sure resume.pdf exists in project root folder)", "info");
                // Open file in new tab (assumes a file named resume.pdf exists)
                setTimeout(() => {
                    window.open('resume.pdf', '_blank');
                }, 1000);
            });
        });

        // Demo / Blueprint button click handler
        document.querySelectorAll('.demo-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const project = e.target.closest('.project-card').querySelector('.project-title').textContent;
                showToast(`Opening demonstration environment for ${project}...`, "info");
            });
        });

        // Verification button click handler
        document.querySelectorAll('.verify-cert-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const cert = btn.getAttribute('data-cert');
                showToast(`Redirecting to verification database for: ${cert}`, "info");
            });
        });
    </script>
</body>
</html>
