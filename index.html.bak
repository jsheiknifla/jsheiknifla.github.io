<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Cybersecurity Portfolio of Sheik Nifla J - Junior SOC Analyst, Security Analyst, Threat Detection & Incident Response">
    <title>Sheik Nifla J | SOC Analyst & Cybersecurity Portfolio</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Manrope:wght@400;500;600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            /* Colors */
            --primary-white: #FFFFFF;
            --cyber-blue: #4F8EF7;
            --accent-pink: #FF5FA2;
            --text-dark: #1A1A2E;
            --text-muted: #555555;
            
            /* Background Gradients */
            --bg-gradient: linear-gradient(135deg, #FDFBFB 0%, #EBEDEE 100%);
            --blue-gradient: linear-gradient(135deg, rgba(79, 142, 247, 0.1) 0%, rgba(255, 255, 255, 0) 100%);
            --pink-gradient: linear-gradient(135deg, rgba(255, 95, 162, 0.1) 0%, rgba(255, 255, 255, 0) 100%);
            
            /* Glassmorphism */
            --glass-bg: rgba(255, 255, 255, 0.6);
            --glass-border: rgba(255, 255, 255, 0.8);
            --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
            
            /* Typography */
            --font-heading: 'Poppins', sans-serif;
            --font-body: 'Inter', sans-serif;
            --font-accent: 'Manrope', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            color: var(--text-dark);
            background: var(--bg-gradient);
            position: relative;
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* Animated Background Particles / Blobs */
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            z-index: -1;
            animation: float 20s infinite ease-in-out alternate;
        }
        .blob-1 {
            width: 400px;
            height: 400px;
            background: rgba(79, 142, 247, 0.3);
            top: 5%;
            left: 10%;
        }
        .blob-2 {
            width: 300px;
            height: 300px;
            background: rgba(255, 95, 162, 0.3);
            top: 20%;
            right: 15%;
            animation-delay: -5s;
        }
        .blob-3 {
            width: 500px;
            height: 500px;
            background: rgba(79, 142, 247, 0.2);
            bottom: 10%;
            left: 30%;
            animation-delay: -10s;
        }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(30px, -50px) scale(1.1); }
            100% { transform: translate(-20px, 20px) scale(0.9); }
        }

        /* Glassmorphism Utilities */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            box-shadow: var(--glass-shadow);
            transition: all 0.3s ease;
        }
        .glass-panel:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.15);
            border-color: rgba(255, 255, 255, 1);
        }

        /* Layout */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }
        section {
            padding: 6rem 0;
            position: relative;
        }
        .section-title {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            text-align: center;
            margin-bottom: 3rem;
            background: linear-gradient(135deg, var(--cyber-blue), var(--accent-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        /* Navbar */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            padding: 1rem 0;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.5);
            transition: all 0.3s ease;
        }
        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }
        .logo {
            font-family: var(--font-accent);
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-dark);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .logo i {
            color: var(--cyber-blue);
        }
        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text-dark);
            font-weight: 500;
            transition: color 0.3s;
            position: relative;
            padding: 0.2rem 0;
        }
        .nav-links a:hover, .nav-links a.active {
            color: var(--cyber-blue);
        }
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(to right, var(--cyber-blue), var(--accent-pink));
            transition: width 0.3s ease;
        }
        .nav-links a:hover::after, .nav-links a.active::after {
            width: 100%;
        }
        
        .nav-toggle {
            display: none;
            background: none;
            border: none;
            color: var(--text-dark);
            font-size: 1.5rem;
            cursor: pointer;
            z-index: 1002;
        }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.8rem 1.8rem;
            border-radius: 30px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            border: none;
            font-family: var(--font-accent);
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--cyber-blue), var(--accent-pink));
            color: white;
            box-shadow: 0 4px 15px rgba(79, 142, 247, 0.3);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 95, 162, 0.4);
        }
        .btn-glass {
            background: rgba(255, 255, 255, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.8);
            color: var(--text-dark);
            backdrop-filter: blur(5px);
        }
        .btn-glass:hover {
            background: rgba(255, 255, 255, 0.8);
            transform: translateY(-2px);
        }
        .btn-sm {
            padding: 0.5rem 1.2rem;
            font-size: 0.85rem;
        }

        /* Hero Section */
        #hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding-top: 5rem;
        }
        .hero-content {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 3rem;
            align-items: center;
        }
        .hero-text h1 {
            font-family: var(--font-heading);
            font-size: 4rem;
            line-height: 1.1;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, var(--text-dark), var(--cyber-blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .typing-text {
            font-family: var(--font-accent);
            font-size: 1.5rem;
            color: var(--accent-pink);
            font-weight: 600;
            margin-bottom: 1.5rem;
            min-height: 36px;
        }
        .hero-desc {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 2rem;
            max-width: 95%;
        }
        .hero-btns {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .hero-img-container {
            position: relative;
            text-align: center;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .hero-img {
            width: 320px;
            height: 320px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid rgba(255,255,255,0.8);
            box-shadow: var(--glass-shadow);
            position: relative;
            z-index: 2;
        }
        .img-backdrop {
            position: absolute;
            width: 340px;
            height: 340px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--cyber-blue), var(--accent-pink));
            z-index: 1;
            opacity: 0.3;
            filter: blur(20px);
            animation: pulse 4s infinite alternate;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.3; }
            100% { transform: scale(1.05); opacity: 0.5; }
        }

        /* Stats Section */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 2rem;
            position: relative;
            z-index: 10;
            padding: 2.5rem;
        }
        .stat-card {
            text-align: center;
            position: relative;
        }
        .stat-card:not(:last-child)::after {
            content: '';
            position: absolute;
            right: -1rem;
            top: 20%;
            height: 60%;
            width: 1px;
            background: rgba(0, 0, 0, 0.1);
        }
        .stat-number {
            font-family: var(--font-heading);
            font-size: 3rem;
            font-weight: 700;
            color: var(--cyber-blue);
            margin-bottom: 0.5rem;
        }
        .stat-text {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }
        .stat-tags {
            font-size: 0.85rem;
            color: var(--accent-pink);
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        .stat-tags span {
            background: rgba(255, 95, 162, 0.1);
            padding: 0.1rem 0.5rem;
            border-radius: 10px;
        }

        /* About Section */
        .about-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }
        .about-glass {
            padding: 2.5rem;
        }
        .about-glass h3 {
            font-family: var(--font-heading);
            margin-bottom: 1.2rem;
            color: var(--cyber-blue);
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .about-glass p {
            margin-bottom: 1rem;
            color: var(--text-muted);
            font-size: 1.05rem;
            text-align: justify;
        }

        /* Experience Timeline */
        .timeline {
            position: relative;
            max-width: 900px;
            margin: 0 auto;
        }
        .timeline::after {
            content: '';
            position: absolute;
            width: 4px;
            background: linear-gradient(to bottom, var(--cyber-blue), var(--accent-pink));
            top: 0;
            bottom: 0;
            left: 50%;
            margin-left: -2px;
            border-radius: 2px;
        }
        .timeline-item {
            padding: 10px 40px;
            position: relative;
            background-color: inherit;
            width: 50%;
        }
        .timeline-item::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            right: -10px;
            background-color: white;
            border: 4px solid var(--cyber-blue);
            top: 25px;
            border-radius: 50%;
            z-index: 1;
            transition: all 0.3s;
        }
        .timeline-item:hover::after {
            background-color: var(--accent-pink);
            border-color: var(--cyber-blue);
            transform: scale(1.2);
        }
        .left { left: 0; }
        .right {
            left: 50%;
        }
        .right::after {
            left: -10px;
        }
        .timeline-content {
            padding: 1.8rem;
        }
        .timeline-content h3 {
            color: var(--cyber-blue);
            margin-bottom: 0.3rem;
            font-family: var(--font-heading);
        }
        .timeline-content h4 {
            color: var(--text-dark);
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 1.05rem;
        }
        .timeline-date {
            color: var(--accent-pink);
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 1rem;
            font-family: var(--font-accent);
        }
        .timeline-content ul {
            padding-left: 1.2rem;
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 1.2rem;
        }
        .timeline-content li {
            margin-bottom: 0.4rem;
        }
        .timeline-tags span {
            display: inline-block;
            background: rgba(79, 142, 247, 0.1);
            color: var(--cyber-blue);
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-size: 0.8rem;
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
            font-weight: 500;
        }

        /* Skills */
        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            justify-content: center;
        }
        .skill-category {
            width: 100%;
            text-align: center;
            margin-bottom: 1rem;
            font-weight: 700;
            color: var(--text-dark);
            margin-top: 2.5rem;
            font-family: var(--font-heading);
            font-size: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .skill-badge {
            padding: 0.8rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            font-weight: 600;
            font-size: 0.95rem;
        }
        .skill-badge i {
            color: var(--accent-pink);
            font-size: 1.2rem;
            transition: transform 0.3s;
        }
        .skill-badge:hover i {
            transform: rotate(15deg) scale(1.2);
        }

        /* Projects */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
        }
        .project-card {
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100%;
            border: 1px solid var(--glass-border);
        }
        .project-img-placeholder {
            height: 220px;
            background: linear-gradient(135deg, rgba(79, 142, 247, 0.15), rgba(255, 95, 162, 0.15));
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--cyber-blue);
            font-size: 3.5rem;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .project-card:hover .project-img-placeholder {
            background: linear-gradient(135deg, rgba(79, 142, 247, 0.25), rgba(255, 95, 162, 0.25));
        }
        .project-img-placeholder span {
            font-size: 1rem;
            font-family: var(--font-accent);
            font-weight: 700;
            margin-top: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dark);
        }
        .project-content {
            padding: 1.8rem;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }
        .project-title {
            font-family: var(--font-heading);
            font-size: 1.4rem;
            margin-bottom: 0.8rem;
            color: var(--text-dark);
            font-weight: 700;
        }
        .project-desc {
            color: var(--text-muted);
            font-size: 0.98rem;
            margin-bottom: 1.5rem;
            flex-grow: 1;
            text-align: justify;
        }
        .project-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
        }
        .project-tech span {
            font-size: 0.8rem;
            background: rgba(79, 142, 247, 0.1);
            color: var(--cyber-blue);
            padding: 0.3rem 0.7rem;
            border-radius: 12px;
            font-weight: 600;
        }
        .project-links {
            display: flex;
            gap: 1rem;
        }
        .project-links .btn {
            padding: 0.6rem 1rem;
            font-size: 0.9rem;
            flex: 1;
            text-align: center;
        }

        /* Certifications */
        .certs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 2rem;
        }
        .cert-card {
            padding: 2rem 1.5rem;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            height: 100%;
        }
        .cert-icon {
            font-size: 3rem;
            color: var(--cyber-blue);
            margin-bottom: 1.2rem;
            transition: transform 0.3s;
        }
        .cert-card:hover .cert-icon {
            transform: scale(1.15) rotate(5deg);
        }
        .cert-title {
            font-weight: 700;
            margin-bottom: 0.5rem;
            font-family: var(--font-heading);
            font-size: 1.15rem;
            color: var(--text-dark);
        }
        .cert-issuer {
            color: var(--text-muted);
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 1rem;
            font-family: var(--font-accent);
        }
        .cert-skills {
            font-size: 0.85rem;
            color: var(--accent-pink);
            margin-bottom: 1.5rem;
            font-weight: 500;
        }

        /* GitHub Stats */
        .github-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }
        .github-card {
            padding: 2rem;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }
        .github-card img {
            max-width: 100%;
            height: auto;
            border-radius: 10px;
            transition: transform 0.3s;
        }
        .github-card:hover img {
            transform: scale(1.02);
        }

        /* Career Goals */
        .roadmap {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.8rem;
            width: 100%;
        }
        .roadmap-step {
            padding: 1.2rem 2rem;
            text-align: center;
            font-weight: 700;
            width: 100%;
            max-width: 320px;
            transition: all 0.3s ease;
            border: 1px solid var(--glass-border);
            font-family: var(--font-accent);
        }
        .roadmap-step:hover {
            background: linear-gradient(135deg, var(--cyber-blue), var(--accent-pink));
            color: white;
            border-color: transparent;
        }
        .roadmap-arrow {
            color: var(--cyber-blue);
            font-size: 1.5rem;
            animation: arrowBounce 1.5s infinite alternate;
        }
        @keyframes arrowBounce {
            0% { transform: translateY(0); }
            100% { transform: translateY(5px); }
        }

        /* Contact */
        .contact-container {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 3rem;
        }
        .contact-info {
            padding: 2.5rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .contact-item {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            margin-bottom: 1.8rem;
        }
        .contact-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(79, 142, 247, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--cyber-blue);
            font-size: 1.2rem;
            flex-shrink: 0;
        }
        .contact-details strong {
            display: block;
            font-size: 0.9rem;
            color: var(--text-dark);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .contact-details a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }
        .contact-details a:hover {
            color: var(--cyber-blue);
        }
        .contact-form {
            padding: 2.5rem;
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-control {
            width: 100%;
            padding: 1.1rem;
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.5);
            font-family: var(--font-body);
            font-size: 0.95rem;
            transition: all 0.3s;
            color: var(--text-dark);
        }
        .form-control:focus {
            outline: none;
            border-color: var(--cyber-blue);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 0 15px rgba(79, 142, 247, 0.15);
        }
        textarea.form-control {
            height: 160px;
            resize: vertical;
        }

        /* Toast Notifications */
        .toast-container {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .toast {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            padding: 1rem 1.8rem;
            border-radius: 12px;
            box-shadow: var(--glass-shadow);
            display: flex;
            align-items: center;
            gap: 0.8rem;
            transform: translateX(120%);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            font-weight: 600;
            color: var(--text-dark);
        }
        .toast.show {
            transform: translateX(0);
        }
        .toast i {
            font-size: 1.2rem;
        }
        .toast-success i { color: #2ecc71; }
        .toast-info i { color: var(--cyber-blue); }

        /* Back to top button */
        .back-to-top {
            position: fixed;
            bottom: 2rem;
            left: 2rem;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--cyber-blue);
            cursor: pointer;
            z-index: 999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }
        .back-to-top.show {
            opacity: 1;
            visibility: visible;
        }
        .back-to-top:hover {
            transform: translateY(-5px);
            background: linear-gradient(135deg, var(--cyber-blue), var(--accent-pink));
            color: white;
            border-color: transparent;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 3rem 0;
            background: rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(5px);
            border-top: 1px solid rgba(255, 255, 255, 0.5);
        }
        .footer-tech {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1rem;
            font-size: 0.85rem;
            color: var(--text-muted);
            flex-wrap: wrap;
        }

        /* Scroll Animation Classes */
        .reveal {
            opacity: 0;
            transform: translateY(35px);
            transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Custom Cursor Glow */
        .cursor-glow {
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(79, 142, 247, 0.15) 0%, rgba(255,255,255,0) 70%);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
            transition: transform 0.1s ease;
        }

        /* Scroll Progress */
        .scroll-progress {
            position: fixed;
            top: 0;
            left: 0;
            width: 0%;
            height: 3px;
            background: linear-gradient(to right, var(--cyber-blue), var(--accent-pink));
            z-index: 1001;
        }

        /* Responsive Styles */
        @media (max-width: 992px) {
            .hero-content {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 2rem;
            }
            .hero-text h1 {
                font-size: 3rem;
            }
            .hero-desc {
                margin: 0 auto 2rem auto;
            }
            .hero-btns {
                justify-content: center;
            }
            .about-content, .contact-container, .github-grid {
                grid-template-columns: 1fr;
            }
            .timeline::after { left: 31px; }
            .timeline-item {
                width: 100%;
                padding-left: 70px;
                padding-right: 25px;
            }
            .timeline-item::after { left: 21px; }
            .right { left: 0%; }
            .stat-card:not(:last-child)::after {
                display: none;
            }
        }
        @media (max-width: 768px) {
            .nav-toggle {
                display: block;
            }
            .nav-links {
                display: flex;
                flex-direction: column;
                position: fixed;
                top: 0;
                right: -100%;
                width: 260px;
                height: 100vh;
                background: rgba(255, 255, 255, 0.95);
                backdrop-filter: blur(15px);
                -webkit-backdrop-filter: blur(15px);
                border-left: 1px solid rgba(255, 255, 255, 0.5);
                padding: 6rem 2rem 2rem 2rem;
                gap: 1.5rem;
                transition: right 0.3s ease-in-out;
                box-shadow: -5px 0 30px rgba(0,0,0,0.1);
            }
            .nav-links.active {
                right: 0;
            }
            .hero-text h1 { font-size: 2.5rem; }
            .hero-img { width: 260px; height: 260px; }
            .img-backdrop { width: 280px; height: 280px; }
            .stat-number { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

